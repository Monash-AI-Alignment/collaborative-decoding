// Cloudflare Workers static-assets config: serves the public research site
// (docs/index.html + docs/data.json) with no Worker script and no build step.
// Deploy command: npx wrangler deploy
{
  "name": "collab-decoding",
  "compatibility_date": "2026-07-01",
  "assets": {
    "directory": "./docs"
  }
}
